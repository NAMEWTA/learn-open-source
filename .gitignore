# Git 相关文件（但保留重要的配置文件）
.git/
# .gitignore (这个文件本身不应该被忽略)
# .gitmodules (这个文件很重要，不应该被忽略)

# 学习笔记和文档
docs/study-notes/
*.log

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE 和编辑器
.vscode/
.idea/
*.swp
*.swo
*~

# 临时文件
*.tmp
*.bak
*.cache

# 构建产物（各个子模块可能有自己的构建目录）
dist/
build/
out/
target/

# 依赖目录（子模块各自管理）
node_modules/
__pycache__/
*.pyc
vendor/

# 环境配置文件（敏感信息）
.env
.env.local
.env.*.local

# 个人配置文件
*.local.yaml
*.local.json
config.local.*

# 大型数据文件
*.iso
*.img
*.zip
*.tar.gz

# 二进制可执行文件
*.exe
*.dll
*.so
*.dylib
